# ============================================
# ArcForge local environment configuration
# ============================================
#
# Setup instructions:
# 1. Create your own PostgreSQL database on Render.
# 2. Copy this file and rename the copy to `.env`.
# 3. Replace every {...} placeholder below with the credentials
#    provided by your Render PostgreSQL database.
# 4. Never commit your `.env` file to GitHub.

# Server
NODE_ENV=development
PORT=3001

# PostgreSQL
PGUSER="{Username}"
PGPASSWORD="{Password}"
PGHOST="{Hostname}.{Region}-postgres.render.com"
PGPORT=5432
PGDATABASE="{Database}"

# Use true for hosted databases that require SSL.
# Use false for a typical local PostgreSQL database.
DB_SSL=true
